---
import BaseLayout from '../layouts/BaseLayout.astro';
import yaml from 'js-yaml';
import fs from 'node:fs';

const grantData = yaml.load(fs.readFileSync('src/data/grants.yaml', 'utf8')) as any;

const external = grantData.external || [];
const internal = grantData.internal || [];

const totalExternal = external.reduce((sum: number, g: any) => {
  const num = parseInt(g.amount.replace(/[^0-9]/g, ''));
  return sum + (isNaN(num) ? 0 : num);
}, 0);
---

<BaseLayout title="Grants" description="Research grants awarded to Joshua McCrain.">

  <h1 class="text-3xl font-bold text-gray-900 dark:text-text-dark-primary mb-2">Grants</h1>
  <p class="text-gray-600 dark:text-text-dark-secondary mb-8">
    Over ${totalExternal.toLocaleString()} in external funding.
  </p>

  <!-- External Grants -->
  <section>
    <h2 class="text-xl font-bold text-gray-900 dark:text-text-dark-primary mb-4">External Grants</h2>
    <div class="space-y-4">
      {external.map((g: any) => (
        <div class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-4 border-b border-gray-100 dark:border-surface-dark-border pb-4">
          <span class="text-sm text-gray-500 dark:text-text-dark-secondary shrink-0 w-12">{g.year}</span>
          <div class="flex-1">
            <div class="flex flex-wrap items-baseline gap-2">
              <h3 class="font-medium text-gray-900 dark:text-text-dark-primary">{g.title}</h3>
              {g.role && (
                <span class="text-xs font-medium text-utah-red">({g.role})</span>
              )}
            </div>
            <p class="text-sm text-gray-600 dark:text-text-dark-secondary">{g.funder}</p>
          </div>
          <span class="text-sm font-semibold text-gray-900 dark:text-text-dark-primary shrink-0">{g.amount}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Internal Grants -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-gray-900 dark:text-text-dark-primary mb-4">Internal Grants</h2>
    <div class="space-y-4">
      {internal.map((g: any) => (
        <div class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-4 border-b border-gray-100 dark:border-surface-dark-border pb-4">
          <span class="text-sm text-gray-500 dark:text-text-dark-secondary shrink-0 w-12">{g.year}</span>
          <div class="flex-1">
            <h3 class="font-medium text-gray-900 dark:text-text-dark-primary">{g.title}</h3>
            <p class="text-sm text-gray-600 dark:text-text-dark-secondary">
              {g.funder}
              {g.note && <span> — {g.note}</span>}
            </p>
          </div>
          <span class="text-sm font-semibold text-gray-900 dark:text-text-dark-primary shrink-0">{g.amount}</span>
        </div>
      ))}
    </div>
  </section>

</BaseLayout>
