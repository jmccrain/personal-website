---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="CV" description="Curriculum Vitae for Joshua McCrain.">

  <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-6 gap-4">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-text-dark-primary">Curriculum Vitae</h1>
    <a
      href="/McCrain_CV.pdf"
      download
      class="inline-flex items-center gap-2 px-4 py-2 bg-utah-red dark:bg-utah-red-light text-white rounded-lg hover:opacity-90 transition-opacity text-sm font-medium hover:no-underline"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      Download PDF
    </a>
  </div>

  <div class="border border-gray-200 dark:border-surface-dark-border rounded-lg overflow-hidden bg-gray-50 dark:bg-surface-dark-raised">
    <iframe
      src="/McCrain_CV.pdf"
      class="w-full"
      style="height: 80vh; min-height: 600px;"
      title="Joshua McCrain CV"
    >
      <p class="p-4 text-gray-600 dark:text-text-dark-secondary">
        Your browser does not support embedded PDFs.
        <a href="/McCrain_CV.pdf" class="text-carolina-blue hover:underline">Download the CV</a> instead.
      </p>
    </iframe>
  </div>

</BaseLayout>
